<?xml version="1.0" ?>
<robot name="robot-gripper">
  <link name="base_link">
    <visual name="base_link_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Base_1.stl"/>
      </geometry>
      <material name="base_link-material">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision name="base_link_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Base_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.015290953"/>
      <inertia ixx="2.1069993e-06" iyy="4.8492375e-06" izz="3.158117e-06" ixy="-5.6211776e-09" ixz="7.1803926e-08" iyz="1.9494126e-07"/>
      <origin xyz="-0.0022614937 -0.0023823638 0.047129642" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="left_drive_gear">
    <visual name="left_drive_gear_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Gear_Arm_2_1.stl"/>
      </geometry>
      <material name="left_drive_gear-material">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision name="left_drive_gear_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Gear_Arm_2_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.0042262329"/>
      <inertia ixx="4.6408343e-07" iyy="3.7357645e-07" izz="8.1436537e-07" ixy="2.6784585e-07" ixz="-1.2441362e-08" iyz="1.5013542e-08"/>
      <origin xyz="-0.0038550445 0.005804216 0.0043127024" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="right_drive_gear">
    <visual name="right_drive_gear_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Gear_Arm_1_1.stl"/>
      </geometry>
      <material name="right_drive_gear-material">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision name="right_drive_gear_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Gear_Arm_1_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.0049578483"/>
      <inertia ixx="4.8434273e-07" iyy="3.8414473e-07" izz="8.3874037e-07" ixy="-2.5279651e-07" ixz="0" iyz="0"/>
      <origin xyz="0.0029128765 0.0047894385 0.003" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="left_inner_link">
    <visual name="left_inner_link_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_2_1.stl"/>
      </geometry>
      <material name="left_inner_link-material">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
    <collision name="left_inner_link_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_2_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.00099845302"/>
      <inertia ixx="8.0913286e-08" iyy="5.2279537e-08" izz="1.3053028e-07" ixy="6.0381679e-08" ixz="0" iyz="0"/>
      <origin xyz="-0.0096130635 0.012158904 0.002" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="left_outer_link">
    <visual name="left_outer_link_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_1.stl"/>
      </geometry>
      <material name="left_outer_link-material">
        <color rgba="1 0 0.5 1"/>
      </material>
    </visual>
    <collision name="left_outer_link_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.00090319457"/>
      <inertia ixx="6.6400522e-08" iyy="4.304676e-08" izz="1.0705886e-07" ixy="-4.9247458e-08" ixz="0" iyz="0"/>
      <origin xyz="-0.0096130635 -0.012158904 0.0018945316" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="right_inner_link">
    <visual name="right_inner_link_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_1_1.stl"/>
      </geometry>
      <material name="right_inner_link-material">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
    <collision name="right_inner_link_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_1_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.00099845302"/>
      <inertia ixx="8.422038e-08" iyy="4.8972443e-08" izz="1.3053028e-07" ixy="-5.9500552e-08" ixz="0" iyz="0"/>
      <origin xyz="0.0092741175 0.012419367 0.002" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="right_outer_link">
    <visual name="right_outer_link_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_3_1.stl"/>
      </geometry>
      <material name="right_outer_link-material">
        <color rgba="1 0 0.5 1"/>
      </material>
    </visual>
    <collision name="right_outer_link_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Link_3_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.00090319457"/>
      <inertia ixx="6.9097797e-08" iyy="4.0349485e-08" izz="1.0705886e-07" ixy="4.8528809e-08" ixz="0" iyz="0"/>
      <origin xyz="0.0092741175 -0.012419367 0.0018945316" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="left_finger">
    <visual name="left_finger_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Grip_1.stl"/>
      </geometry>
      <material name="left_finger-material">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
    <collision name="left_finger_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Grip_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.0066992081"/>
      <inertia ixx="2.0222135e-06" iyy="1.6442043e-07" izz="2.1064359e-06" ixy="-3.1587483e-07" ixz="1.0017541e-09" iyz="4.1254081e-09"/>
      <origin xyz="0.006584434 0.026658842 -0.0042268708" rpy="0 0 0"/>
    </inertial>
  </link>

  <link name="right_finger">
    <visual name="right_finger_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Grip_1_1.stl"/>
      </geometry>
      <material name="right_finger-material">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision name="right_finger_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/Grip_1_1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.006699208"/>
      <inertia ixx="2.0387543e-06" iyy="1.4787976e-07" izz="2.106436e-06" ixy="2.6224825e-07" ixz="-9.1824129e-10" iyz="4.1558634e-09"/>
      <origin xyz="-0.0058193137 0.026836249 -0.0042269163" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- DUMMY LINKS FOR LOOP CLOSURES -->
  <link name="left_finger_inner_dummy"/>
  <link name="left_finger_outer_dummy"/>
  <link name="right_finger_inner_dummy"/>
  <link name="right_finger_outer_dummy"/>

  <!-- MASTER ACTUATION JOINT (Left Side) -->
  <joint name="left_drive_joint" type="revolute">
    <origin xyz="-0.01676179 -0.00753234 0.04544358" rpy="1.5707963 0 0"/>
    <parent link="base_link"/>
    <child link="left_drive_gear"/>
    <axis xyz="0 0 -1"/>
    <limit effort="1" velocity="1" lower="-1.5708" upper="1.5708"/>
  </joint>

  <!-- SLAVE GEAR JOINT (Right Side) -->
  <joint name="right_drive_joint" type="continuous">
    <origin xyz="0.01013821 -0.00753234 0.04544358" rpy="1.5707963 0 0"/>
    <parent link="base_link"/>
    <child link="right_drive_gear"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <!-- LEFT SIDE PARALLEL LINKS -->
  <joint name="left_inner_base_joint" type="continuous">
    <origin xyz="-0.00831179 -0.00753234 0.06544358" rpy="1.5707963 0 0"/>
    <parent link="base_link"/>
    <child link="left_inner_link"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="left_outer_base_joint" type="continuous">
    <origin xyz="-0.00831179 0.00096766 0.06544358" rpy="-1.5707963 0 0"/>
    <parent link="base_link"/>
    <child link="left_outer_link"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <!-- RIGHT SIDE PARALLEL LINKS -->
  <joint name="right_inner_base_joint" type="continuous">
    <origin xyz="0.00168821 -0.00753234 0.06544358" rpy="1.5707963 0 0"/>
    <parent link="base_link"/>
    <child link="right_inner_link"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="right_outer_base_joint" type="continuous">
    <origin xyz="0.00168821 0.00096766 0.06544358" rpy="-1.5707963 0 0"/>
    <parent link="base_link"/>
    <child link="right_outer_link"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <!-- FINGER DRIVE JOINTS -->
  <joint name="left_finger_gear_joint" type="continuous">
    <origin xyz="-0.01906385 0.02412741 0" rpy="0 0 0"/>
    <parent link="left_drive_gear"/>
    <child link="left_finger"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="right_finger_gear_joint" type="continuous">
    <origin xyz="0.01870495 0.0244067 0" rpy="0 0 0"/>
    <parent link="right_drive_gear"/>
    <child link="right_finger"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <!-- LOOP CLOSING JOINTS (Connecting to Dummy Links) -->
  <joint name="left_finger_inner_joint" type="continuous">
    <origin xyz="-0.01922613 0.02431781 0" rpy="0 0 0"/>
    <parent link="left_inner_link"/>
    <child link="left_finger_inner_dummy"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="left_finger_outer_joint" type="continuous">
    <origin xyz="0.00873772 0.0201904 -0.0085" rpy="0 0 0"/>
    <parent link="left_outer_link"/>
    <child link="left_finger_outer_dummy"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="right_finger_inner_joint" type="continuous">
    <origin xyz="0.01854823 0.02483874 0" rpy="0 0 0"/>
    <parent link="right_inner_link"/>
    <child link="right_finger_inner_dummy"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="right_finger_outer_joint" type="continuous">
    <origin xyz="0.01854823 -0.02483874 0" rpy="0 0 0"/>
    <parent link="right_outer_link"/>
    <child link="right_finger_outer_dummy"/>
    <axis xyz="0 0 -1"/>
  </joint>

</robot>
